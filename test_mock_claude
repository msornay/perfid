# ── Helpers ──────────────────────────────────────────────────────────


def get_power():
    """Determine power from GNUPGHOME path.

    setup_turn_gpg sets GNUPGHOME=/tmp/gpg-<lowercase power>.
    """
    gnupghome = os.environ.get('GNUPGHOME', '')
    name = os.path.basename(gnupghome).replace('gpg-', '')
    return name[0].upper() + name[1:] if name else ''


def print_position(state, power):
    """Print unit and SC summary for a power."""
    units = state.get('units', {}).get(power, [])
    sc_count = sum(
        1 for v in state.get('sc_ownership', {}).values()
        if v == power
    )
    sc_names = sorted(
        k for k, v in state.get('sc_ownership', {}).items()
        if v == power
    )
    print(f"Position: {len(units)} units, {sc_count} SCs "
          f"({', '.join(sc_names)})")


def print_inbox(power, gnupghome, game_dir='/game'):
    """Read and decrypt inbox messages. Returns list of messages."""
    messages = list_inbox(game_dir, power)
    if not messages:
        print("Inbox: (empty)")
        return []

    print("Inbox:")
    decrypted = []
    for msg in messages:
        sender = msg['sender']
        path = msg['path']
        try:
            text = gpg_mod.decrypt_file(gnupghome, path)
            print(f'  From {sender}: "{text}"')
            decrypted.append((sender, text))
        except Exception:
            # Fall back to gpg subprocess if module fails
            try:
                result = subprocess.run(
                    ['gpg', '--batch', '--yes', '--homedir',
                     gnupghome, '--decrypt', path],
                    capture_output=True,
                )
                if result.returncode == 0:
                    text = result.stdout.decode()
                    print(f'  From {sender}: "{text}"')
                    decrypted.append((sender, text))
                else:
                    print(f'  From {sender}: (decrypt failed)')
            except Exception:
                print(f'  From {sender}: (decrypt failed)')
    return decrypted


def print_simulation(result, power, orders):
    """Print per-order simulation results."""
    print("Simulating with jDip:")
    order_results = result.get('order_results', [])

    # Build a map from order text to result
    result_map = {}
    for entry in order_results:
        # order format: "Power: A Location - Destination"
        order_text = entry.get('order', '')
        if ':' in order_text:
            order_text = order_text.split(':', 1)[1].strip()
        status = entry.get('result', 'unknown')
        result_map[order_text] = status

    for order in orders:
        status = result_map.get(order, 'unknown')
        # Normalize status display
        if 'success' in status.lower() or status.lower() == 'success':
            display = 'SUCCESS'
        elif 'bounce' in status.lower():
            display = 'BOUNCE'
        elif 'fail' in status.lower() or 'dislodge' in status.lower():
            display = 'FAIL'
        else:
            display = status.upper()
        print(f"  {order:<45s} -> {display}")


# ── Main ─────────────────────────────────────────────────────────────


def main():
    game_dir = os.environ.get('PERFID_GAME_DIR', '/game')
    dropbox = os.environ.get('PERFID_DROPBOX', '')
    state = load_state(game_dir)
    power = get_power()
    gnupghome = os.environ['GNUPGHOME']
    year = state['year']
    phase = state['phase']

    print(f"\n=== {power} — {phase} {year} ===\n")

    # At year 1902+, signal the game loop to stop by exiting
    # with code 42. The test expects a timeout or non-zero exit.
    if year >= 1902:
        print(f"Year {year} reached. Test scenario complete.\n")
        sys.exit(42)
        return

    orders = SCENARIO.get(phase, {}).get(power, [])
    strategy = STRATEGY.get(phase, {}).get(power, '')

    # Position summary
    print_position(state, power)
    print()

    # Read inbox (exercises real GPG decrypt path)
    print_inbox(power, gnupghome, game_dir)
    print()

    # Strategy reasoning
    if strategy:
        print(f"Strategy: {strategy}")
        print()

    # Movement phases: simulate with jDip, then submit
    if phase in ('Spring', 'Fall') and orders:
        result = simulate(state, {power: orders})
        print_simulation(result, power, orders)
        print()
        print("Submitting orders:")
        for order in orders:
            print(f"  {order}")
        submit_orders(
            game_dir, power, year, phase, orders, gnupghome,
            dropbox=dropbox or None,
        )
        print()

    # Retreat: submit directly with reasoning
    if phase == 'Fall Retreat' and orders:
        # Show dislodgement info
        dislodged = state.get('dislodged', [])
        for d in dislodged:
            if d['power'] == power:
                unit = d['unit']
                retreats = d.get('retreats', [])
                print(f"Dislodged: {unit['type']} {unit['location']}")
                print(f"Retreat options: {', '.join(retreats)}")
                print()
        print("Submitting retreat orders:")
        for order in orders:
            print(f"  {order}")
        submit_orders(
            game_dir, power, year, phase, orders, gnupghome,
            dropbox=dropbox or None,
        )
        print()

    # Winter Adjustment: submit directly with reasoning
    if phase == 'Winter Adjustment' and orders:
        # Show SC vs unit delta
        n_units = len(state.get('units', {}).get(power, []))
        n_sc = sum(
            1 for v in state.get('sc_ownership', {}).values()
            if v == power
        )
        delta = n_sc - n_units
        if delta > 0:
            print(f"Adjustment: {n_sc} SCs, {n_units} units "
                  f"(+{delta} builds)")
        elif delta < 0:
            print(f"Adjustment: {n_sc} SCs, {n_units} units "
                  f"({delta} disbands)")
        else:
            print(f"Adjustment: {n_sc} SCs, {n_units} units "
                  f"(no change)")
        print()
        print("Submitting adjustment orders:")
        for order in orders:
            print(f"  {order}")
        submit_orders(
            game_dir, power, year, phase, orders, gnupghome,
            dropbox=dropbox or None,
        )
        print()

    # Send diplomatic messages (Spring only)
    if phase == 'Spring':
        sent_any = False
        for sender, recipient, text in SPRING_MESSAGES:
            if sender == power:
                ct = gpg_mod.encrypt(
                    gnupghome, text,
                    f'{recipient.lower()}@perfid.local',
                )
                send_message(
                    game_dir, power, recipient, phase, 1, ct,
                )
                print(f'Sending message to {recipient}: "{text}"')
                sent_any = True
        if not sent_any:
            print("No messages to send this turn.")
    print()

    print(f"=== {power} done ===")


if __name__ == '__main__':
    main()
