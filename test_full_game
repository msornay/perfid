#!/usr/bin/env bash
# Full-game integration test: runs perfid play end-to-end with a mock claude.
#
# Uses production code paths for everything — GPG encryption, jDip
# adjudication, order submission, message routing. Only the AI
# decision-making (claude) is replaced with prerecorded scenario data.
#
# In the new architecture, perfid runs INSIDE the container as Python.
# The mock claude is installed in the container's PATH, and perfid
# calls it via sudo -u player.
#
# Scenario: complete 1901 year with a dislodgement (Russia dislodges
# Austria from Galicia via supported attack), retreat, and winter builds.
#
# Requires Docker — builds and runs the player container image.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# Short path to avoid GPG agent socket length limit (108 chars)
TEST_WS="/tmp/perfid-t$$"
mkdir -p "$TEST_WS"

PLAYER_IMAGE="perfid-player-test-$$"

pass=0
fail=0
game_id="full-$$"
ctr_name="perfid-test-${game_id}"

cleanup() {
    docker rm -f "$ctr_name" 2>/dev/null || true
    docker rmi "$PLAYER_IMAGE" 2>/dev/null || true
    rm -rf "$TEST_WS"
}
trap cleanup EXIT

ok() { pass=$((pass + 1)); echo "ok   - $1"; }
ko() { fail=$((fail + 1)); echo "FAIL - $1"; }

# Run a command with a timeout (portable: timeout, gtimeout, or perl)
run_with_timeout() {
    local secs=$1; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$secs" "$@"
    elif command -v gtimeout >/dev/null 2>&1; then
        gtimeout "$secs" "$@"
    else
        perl -e 'alarm shift @ARGV; exec @ARGV' "$secs" "$@"
    fi
}

echo "=== Full-game integration test (requires Docker) ==="

# ===== Build image =====

echo "  Building player image..."
if docker build -f "$SCRIPT_DIR/Dockerfile.player" -t "$PLAYER_IMAGE" "$SCRIPT_DIR" >/dev/null 2>&1; then
    ok "player image built"
else
    ko "player image build failed"
    echo "FATAL: cannot continue without image" >&2
    exit 1
fi

# ===== Create game =====

# Run perfid new inside a container
mkdir -p "$TEST_WS/g"
if docker run --rm \
    -v "$TEST_WS/g:/games" \
    -e PERFID_GAMES_DIR=/games \
    "$PLAYER_IMAGE" new "$game_id" >/dev/null 2>&1; then
    ok "perfid new creates game"
else
    ko "perfid new creates game"
    echo "FATAL: cannot continue without game" >&2
    exit 1
fi

gd="$TEST_WS/g/$game_id"

# Verify keys were generated (new does bootstrap automatically)
key_count=$(find "$gd/keys" -name "*.key.gpg" 2>/dev/null | wc -l | tr -d ' ')
if [[ "$key_count" -eq 7 ]]; then
    ok "perfid new generates all 7 player keys"
else
    ko "perfid new generates keys (found $key_count, expected 7)"
    echo "FATAL: cannot continue without keys" >&2
    exit 1
fi

# ===== Install mock claude and run game =====

# Run the game loop in a persistent container with mock claude
echo "  Starting game container..."
docker run -d --name "$ctr_name" \
    --entrypoint "" \
    -v "$TEST_WS/g:/games" \
    -e PERFID_GAMES_DIR=/games \
    "$PLAYER_IMAGE" sleep infinity >/dev/null

# Install mock claude (replaces the real claude binary)
docker cp "$SCRIPT_DIR/test_mock_claude" "$ctr_name:/usr/local/bin/claude"
docker exec "$ctr_name" chmod +x /usr/local/bin/claude

echo "  Running perfid play (timeout 60s)..."
run_with_timeout 60 docker exec \
    -e PERFID_GAMES_DIR=/games \
    -e PERFID_MIN_ROUNDS=1 \
    "$ctr_name" python3 /perfid/perfid play "$game_id" \
    >"$TEST_WS/play.log" 2>&1
play_rc=$?

# Mock claude exits 42 at 1902 → perfid exits 1 (PerfidError)
if [[ $play_rc -eq 1 ]]; then
    ok "play loop stopped at 1902 (agent signalled completion)"
elif [[ $play_rc -eq 0 ]]; then
    ok "play loop exited cleanly"
else
    ko "play exited with unexpected code $play_rc"
    echo "  Play log tail:" >&2
    tail -30 "$TEST_WS/play.log" >&2
fi

# ===== Assertions =====

# Helper: read a value from state.json via Python
py_state() {
    python3 -c "
import json
with open('$gd/state.json') as f:
    d = json.load(f)
$1
"
}

echo ""
echo "--- State assertions ---"

state_year=$(py_state "print(d['year'])")
state_phase=$(py_state "print(d['phase'])")
state_winner=$(py_state "print(d['winner'])")

if [[ "$state_year" == "1902" ]]; then ok "year is 1902"
else ko "year: expected 1902, got $state_year"; fi

if [[ "$state_phase" == "Spring" ]]; then ok "phase is Spring"
else ko "phase: expected Spring, got $state_phase"; fi

if [[ "$state_winner" == "None" ]]; then ok "no winner yet"
else ko "winner: expected None, got $state_winner"; fi

echo ""
echo "--- GPG key assertions ---"

for power in Austria England France Germany Italy Russia Turkey; do
    key_file="$gd/keys/${power}.key.gpg"
    if [[ -f "$key_file" ]]; then
        # gpg --list-packets exits non-zero when it can't decrypt, so
        # capture output first to avoid pipefail false-negatives
        packets=$(gpg --list-packets "$key_file" 2>/dev/null || true)
        if echo "$packets" | grep -q "pubkey enc packet"; then
            ok "$power key is GPG-encrypted (asymmetric)"
        else
            ko "$power key is not GPG-encrypted"
        fi
    else
        ko "$power key file missing"
    fi
done

echo ""
echo "--- Order file assertions ---"

count_orders() {
    local dir="$gd/orders/1901/$1"
    if [[ -d "$dir" ]]; then
        find "$dir" -name "*.gpg" | wc -l | tr -d ' '
    else
        echo 0
    fi
}

spring_n=$(count_orders "Spring")
fall_n=$(count_orders "Fall")
retreat_n=$(count_orders "Fall_Retreat")
winter_n=$(count_orders "Winter_Adjustment")

if [[ "$spring_n" -eq 7 ]]; then ok "Spring 1901: $spring_n/7 order files"
else ko "Spring 1901: $spring_n/7 order files"; fi

if [[ "$fall_n" -eq 7 ]]; then ok "Fall 1901: $fall_n/7 order files"
else ko "Fall 1901: $fall_n/7 order files"; fi

if [[ "$retreat_n" -eq 1 ]]; then ok "Fall Retreat 1901: $retreat_n/1 order files"
else ko "Fall Retreat 1901: $retreat_n/1 order files"; fi

if [[ "$winter_n" -eq 7 ]]; then ok "Winter 1901: $winter_n/7 order files"
else ko "Winter 1901: $winter_n/7 order files"; fi

echo ""
echo "--- Message assertions ---"

# Messages are archived after the phase; search the whole tree
check_msg() {
    local sender=$1 recipient=$2
    if find "$gd/messages" -name "${sender}-to-${recipient}-*" 2>/dev/null | grep -q .; then
        ok "message from $sender to $recipient exists"
    else
        ko "message from $sender to $recipient missing"
    fi
}

check_msg France England
check_msg England France
check_msg Germany Russia
check_msg Russia Turkey

echo ""
echo "--- SC ownership assertions ---"

sc_owner() {
    py_state "print(d['sc_ownership'].get('$1', 'NONE'))"
}

check_sc() {
    local sc=$1 expected=$2
    actual=$(sc_owner "$sc")
    if [[ "$actual" == "$expected" ]]; then ok "SC $sc owned by $expected"
    else ko "SC $sc: expected $expected, got $actual"; fi
}

# New captures after Fall 1901
check_sc Serbia Austria
check_sc Greece Austria
check_sc Norway England
check_sc Belgium France
check_sc Spain France
check_sc Portugal France
check_sc Denmark Germany
check_sc Holland Germany
check_sc Trieste Italy
check_sc Tunis Italy
check_sc Rumania Russia
check_sc Bulgaria Turkey

echo ""
echo "--- Unit count assertions ---"

unit_count() {
    py_state "print(len(d['units'].get('$1', [])))"
}

# After Winter builds, unit count must equal SC count for each power
mismatch=false
for power in Austria England France Germany Italy Russia Turkey; do
    n_units=$(unit_count "$power")
    n_sc=$(py_state "print(sum(1 for v in d['sc_ownership'].values() if v == '$power'))")
    if [[ "$n_units" != "$n_sc" ]]; then
        ko "$power: $n_units units but $n_sc SCs"
        mismatch=true
    fi
done
if [[ "$mismatch" == "false" ]]; then
    ok "all powers: unit count matches SC count"
fi

# Specific unit counts (after builds)
for pair in "Austria:4" "England:4" "France:6" "Germany:5" "Italy:5" "Russia:5" "Turkey:4"; do
    power="${pair%%:*}"
    expected="${pair##*:}"
    actual=$(unit_count "$power")
    if [[ "$actual" == "$expected" ]]; then ok "$power has $expected units"
    else ko "$power: expected $expected units, got $actual"; fi
done

echo ""
echo "--- Phase progression assertions ---"

# Fall Retreat was processed (not skipped)
if [[ -d "$gd/orders/1901/Fall_Retreat" ]]; then
    ok "Fall Retreat directory exists (phase was not skipped)"
else
    ko "Fall Retreat directory missing (phase may have been skipped)"
fi

# Austria retreated to Vienna (verify unit present after builds)
has_vienna=$(py_state "
units = d['units'].get('Austria', [])
print(any(u['location'] == 'Vienna' for u in units))
")
if [[ "$has_vienna" == "True" ]]; then
    ok "Austria has unit in Vienna (retreat destination)"
else
    ko "Austria missing unit in Vienna"
fi

echo ""
echo "--- Log assertions ---"

if [[ -f "$gd/log.jsonl" ]]; then ok "game log exists"
else ko "game log not found"; fi

if [[ -f "$gd/log.jsonl" ]]; then
    # agent_turn events with encrypted output
    agent_turn_count=$(python3 -c "
import json
count = 0
with open('$gd/log.jsonl') as f:
    for line in f:
        try:
            e = json.loads(line)
            if e['event'] == 'agent_turn':
                count += 1
        except (json.JSONDecodeError, KeyError):
            pass
print(count)
")
    if [[ "$agent_turn_count" -ge 22 ]]; then
        ok "log has $agent_turn_count agent_turn events (>=22)"
    else
        ko "log has $agent_turn_count agent_turn events (expected >=22)"
    fi

    # agent_turn events have encrypted_output (PGP message)
    has_encrypted=$(python3 -c "
import json
found = False
with open('$gd/log.jsonl') as f:
    for line in f:
        try:
            e = json.loads(line)
            if e['event'] == 'agent_turn':
                enc = e.get('encrypted_output', '')
                if 'BEGIN PGP MESSAGE' in enc:
                    found = True
                    break
        except (json.JSONDecodeError, KeyError):
            pass
print(found)
")
    if [[ "$has_encrypted" == "True" ]]; then
        ok "agent_turn events contain encrypted output"
    else
        ko "agent_turn events missing encrypted output"
    fi

    # message_routed events
    msg_count=$(python3 -c "
import json
count = 0
with open('$gd/log.jsonl') as f:
    for line in f:
        try:
            if json.loads(line)['event'] == 'message_routed':
                count += 1
        except (json.JSONDecodeError, KeyError):
            pass
print(count)
")
    if [[ "$msg_count" -ge 4 ]]; then
        ok "log has $msg_count message_routed events (>=4)"
    else
        ko "log has $msg_count message_routed events (expected >=4)"
    fi

    # adjudication events
    adj_count=$(python3 -c "
import json
count = 0
with open('$gd/log.jsonl') as f:
    for line in f:
        try:
            e = json.loads(line)
            if e['event'] == 'adjudication':
                count += 1
        except (json.JSONDecodeError, KeyError):
            pass
print(count)
")
    if [[ "$adj_count" -ge 2 ]]; then
        ok "log has $adj_count adjudication events (>=2)"
    else
        ko "log has $adj_count adjudication events (expected >=2)"
    fi

    # decrypt_log.py can decrypt the log
    python3 "$SCRIPT_DIR/decrypt_log.py" \
        --gm-key "$gd/gm-gpg" "$gd/log.jsonl" \
        >"$TEST_WS/dec.jsonl" 2>"$TEST_WS/dec.err" || true
    dec_count=$(cat "$TEST_WS/dec.err" | grep -o '[0-9]*' | head -1)
    if [[ -n "$dec_count" ]] && [[ "$dec_count" -gt 0 ]]; then
        ok "decrypt_log.py decrypted $dec_count events"
    else
        ko "decrypt_log.py failed to decrypt events"
    fi

    # Decrypted output contains Strategy: reasoning
    has_strategy=$(python3 -c "
import json
found = False
with open('$TEST_WS/dec.jsonl') as f:
    for line in f:
        try:
            e = json.loads(line)
            if e.get('event') == 'agent_turn' and 'Strategy:' in e.get('output', ''):
                found = True
                break
        except (json.JSONDecodeError, KeyError):
            pass
print(found)
" || echo "False")
    if [[ "$has_strategy" == "True" ]]; then
        ok "decrypted agent_turn output contains Strategy: reasoning"
    else
        ko "decrypted agent_turn output missing Strategy: reasoning"
    fi

    # No plaintext agent reasoning in unencrypted log
    has_plaintext=$(python3 -c "
import json
found = False
with open('$gd/log.jsonl') as f:
    for line in f:
        try:
            e = json.loads(line)
            if e.get('event') == 'agent_turn':
                # Should NOT have plaintext 'output', only 'encrypted_output'
                if 'output' in e and 'Strategy:' in e.get('output', ''):
                    found = True
                    break
        except (json.JSONDecodeError, KeyError):
            pass
print(found)
")
    if [[ "$has_plaintext" == "False" ]]; then
        ok "no plaintext agent reasoning in unencrypted log"
    else
        ko "plaintext agent reasoning found in unencrypted log!"
    fi
fi

echo ""
echo "--- Verbose output assertions ---"

if [[ -f "$TEST_WS/play.log" ]]; then
    # Uppercase turn headers from game_loop
    if grep -q '=== [A-Z].* (round [0-9])' "$TEST_WS/play.log"; then
        ok "play.log has uppercase turn headers"
    else
        ko "play.log missing uppercase turn headers"
    fi

    # Per-order adjudication results (jDip returns lowercase statuses)
    if grep -q 'Order results:' "$TEST_WS/play.log"; then
        ok "play.log has per-order adjudication results"
    else
        ko "play.log missing per-order adjudication results"
    fi

    # Dislodged units reported
    if grep -q 'Dislodged:' "$TEST_WS/play.log"; then
        ok "play.log reports dislodged units"
    else
        ko "play.log missing dislodged unit reports"
    fi

    # SC ownership changes reported
    if grep -q 'SC ownership changes:' "$TEST_WS/play.log"; then
        ok "play.log reports SC ownership changes"
    else
        ko "play.log missing SC ownership changes"
    fi

    # Adjustment counts reported
    if grep -qE '\+[0-9]+ build' "$TEST_WS/play.log"; then
        ok "play.log reports adjustment counts"
    else
        ko "play.log missing adjustment counts"
    fi
else
    ko "play.log not found"
fi

echo ""
echo "--- JSONL feature assertions ---"

if [[ -f "$gd/log.jsonl" ]]; then
    # adjudication events have sc_changes field
    has_sc_changes=$(python3 -c "
import json
found = False
with open('$gd/log.jsonl') as f:
    for line in f:
        try:
            e = json.loads(line)
            if e.get('event') == 'adjudication' and 'sc_changes' in e:
                found = True
                break
        except (json.JSONDecodeError, KeyError):
            pass
print(found)
")
    if [[ "$has_sc_changes" == "True" ]]; then
        ok "adjudication events have sc_changes field"
    else
        ko "adjudication events missing sc_changes field"
    fi

    # adjustments_applied events have adjustment_counts field
    has_adj_counts=$(python3 -c "
import json
found = False
with open('$gd/log.jsonl') as f:
    for line in f:
        try:
            e = json.loads(line)
            if e.get('event') == 'adjustments_applied' and 'adjustment_counts' in e:
                found = True
                break
        except (json.JSONDecodeError, KeyError):
            pass
print(found)
")
    if [[ "$has_adj_counts" == "True" ]]; then
        ok "adjustments_applied events have adjustment_counts field"
    else
        ko "adjustments_applied events missing adjustment_counts field"
    fi
fi

echo ""
echo "--- Security assertions ---"

if [[ ! -f "$gd/master.passphrase" ]]; then ok "master.passphrase never created"
else ko "master.passphrase exists!"; fi

# ===== Results =====

echo ""
echo "=== Results ==="
echo "$((pass + fail)) tests, $pass passed, $fail failed"
[[ $fail -eq 0 ]]
