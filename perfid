#!/usr/bin/env python3
"""perfid — Orchestrate 7 Claude agents playing Diplomacy with GPG encryption.

Runs inside the container. Container lifecycle (create/destroy) is
handled by the Makefile. This script handles game initialization,
the main game loop, and status reporting.

Game data lives in $PERFID_GAMES_DIR/<game-id>/ (default: perfid-games/).
"""

import argparse
import os
import sys

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
GAMES_DIR = os.environ.get("PERFID_GAMES_DIR", "perfid-games")

# Ensure script directory is on the Python path for module imports
if SCRIPT_DIR not in sys.path:
    sys.path.insert(0, SCRIPT_DIR)


from game_loop import PerfidError, emit  # noqa: E402
from game_state import POWERS, new_game, load_state, format_status  # noqa: E402
from prompt import PROFILES  # noqa: E402
from gpg import generate_player_key  # noqa: E402
from message_router import init_message_dirs  # noqa: E402


GAME_ID_PATTERN = r'^[a-zA-Z0-9][a-zA-Z0-9_.\-]*$'


def validate_game_id(game_id):
    """Validate game-id format."""
    import re
    if not re.match(GAME_ID_PATTERN, game_id):
        raise PerfidError(
            f"invalid game-id '{game_id}'. "
            "Use only letters, digits, hyphens, underscores, and dots."
        )
    return game_id


def game_dir(game_id):
    """Return the game directory path."""
    return os.path.join(GAMES_DIR, game_id)


def require_game_exists(game_id):
    """Verify a game exists and return its directory."""
    gd = game_dir(game_id)
    if not os.path.isfile(os.path.join(gd, "state.json")):
        raise PerfidError(f"game '{game_id}' not found at {gd}")
    return gd


def cmd_new(args):
    """Create a new game: directory, state, GM keys, player keys."""
    game_id = validate_game_id(args.game_id)
    gd = game_dir(game_id)

    if os.path.isdir(gd):
        raise PerfidError(f"game directory {gd} already exists.")

    print(f"Creating game '{game_id}'...")

    # Initialize game state and message directories
    state = new_game(game_id, gd, profile=args.profile)
    init_message_dirs(gd, state["units"].keys())
    print(f"Game state initialized: {state['year']} {state['phase']}")

    # Create additional directories
    for subdir in ("pubkeys", "orders", "notes"):
        os.makedirs(os.path.join(gd, subdir), exist_ok=True)

    # Generate GM GPG key
    gm_gpg = os.path.join(gd, "gm-gpg")
    os.makedirs(gm_gpg, mode=0o700, exist_ok=True)

    from gpg import generate_key, export_public_key
    generate_key(gm_gpg, "GM", "gm@perfid.local")
    gm_pub = export_public_key(gm_gpg, "gm@perfid.local")
    pubkey_path = os.path.join(gd, "pubkeys", "GM.asc")
    with open(pubkey_path, "w") as f:
        f.write(gm_pub)
    print("GM GPG key generated.")

    # Generate player keys (replaces separate bootstrap step)
    print("Generating player keys...")
    for power in POWERS:
        print(f"  Generating keys for {power}...")
        generate_player_key(gd, power, gm_gpg)

    emit("game_created", game_id=game_id, powers=POWERS)

    print(f"Game '{game_id}' created at {gd}")
    print(f"Keys stored in {gd}/keys/ and {gd}/pubkeys/")


def cmd_play(args):
    """Run the main game loop."""
    game_id = validate_game_id(args.game_id)
    require_game_exists(game_id)

    import game_loop
    game_loop.run(game_id, GAMES_DIR, SCRIPT_DIR)


def cmd_status(args):
    """Print current game status."""
    game_id = validate_game_id(args.game_id)
    gd = require_game_exists(game_id)

    state = load_state(gd)
    print(format_status(state))


def main():
    parser = argparse.ArgumentParser(
        prog="perfid",
        description="perfid — 7 Claude agents play Diplomacy "
                    "with GPG encryption",
    )
    subparsers = parser.add_subparsers(dest="command")

    new_p = subparsers.add_parser(
        "new",
        help="Create game, GM keys, and player keys",
    )
    new_p.add_argument("game_id", help="Unique game identifier")
    new_p.add_argument(
        "--profile", default="minimal",
        choices=sorted(PROFILES),
        help="Agent profile for all powers (default: minimal)",
    )

    play_p = subparsers.add_parser(
        "play",
        help="Main loop: negotiation → orders → adjudicate",
    )
    play_p.add_argument("game_id", help="Game identifier")

    status_p = subparsers.add_parser(
        "status",
        help="Print current standings",
    )
    status_p.add_argument("game_id", help="Game identifier")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    commands = {
        "new": cmd_new,
        "play": cmd_play,
        "status": cmd_status,
    }

    try:
        commands[args.command](args)
    except PerfidError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        print("\nInterrupted.", file=sys.stderr)
        sys.exit(130)


if __name__ == "__main__":
    main()
