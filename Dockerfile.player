FROM node:20-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       gnupg python3 default-jre-headless sudo \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

# Create unprivileged player user; allow root to sudo as player
RUN useradd -m player \
    && echo "root ALL=(player) NOPASSWD: ALL" >> /etc/sudoers

# Copy perfid Python modules into the container
COPY *.py /perfid/
COPY perfid /perfid/perfid
RUN chmod +x /perfid/perfid

# Copy jDip
COPY jdip/ /perfid/jdip/

WORKDIR /games

# Container runs perfid directly (no Docker-from-Docker)
ENTRYPOINT ["python3", "/perfid/perfid"]
CMD ["--help"]
